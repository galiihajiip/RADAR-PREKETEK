# Public app URL used by links and CORS in local demo.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public app name used by the Next.js MVP UI.
NEXT_PUBLIC_APP_NAME=RADAR
# Supabase project URL; unused when DEMO_MODE=true.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
# Supabase anon key; unused when DEMO_MODE=true.
NEXT_PUBLIC_SUPABASE_ANON_KEY=demo-anon-key-not-for-production
# Server-only Supabase key for production operations. Never expose publicly.
SUPABASE_SERVICE_ROLE_KEY=demo-service-role-key-not-for-production
# PostgreSQL connection string for production-like mode.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/radar
# Flask AI service URL.
AI_SERVICE_URL=http://localhost:5001
# Server demo fallback switch.
DEMO_MODE=true
# Browser-visible demo fallback switch.
NEXT_PUBLIC_DEMO_MODE=true
# JWT signing secret for production auth.
JWT_SECRET=change-me-in-production
# Storage bucket for report images.
STORAGE_BUCKET_REPORTS=report-images
# AI fallback switch when model or Flask is unavailable.
DEMO_AI_FALLBACK=true
# Optional TorchScript model path.
MODEL_PATH=ml/models/radar_mobilenetv3_small.ts
# CORS allowlist for Flask.
CORS_ORIGINS=http://localhost:3000
# Postgres password for docker profile db.
POSTGRES_PASSWORD=postgres
